{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "CI=1 EXPO_NO_TELEMETRY=1 npx expo start --web --port ${PORT:-8081}"],
      "port": 8081,
      "autoPort": true
    },
    {
      "name": "prod-proxy",
      "runtimeExecutable": "node",
      "runtimeArgs": [".claude/prod-proxy.js"],
      "port": 4173,
      "autoPort": true
    }
  ]
}
